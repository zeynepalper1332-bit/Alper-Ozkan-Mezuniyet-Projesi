"use client";

export const dynamic = "force-dynamic";

import { useEffect, useState } from "react";
import { collection, query, where, getDocs, doc, updateDoc } from "firebase/firestore";
import { db } from "@/lib/firebase";
import { useAuth } from "@/app/_context/AuthContext";
import { UserProfile } from "@/lib/types";

export default function StudentsPage() {
  const { profile } = useAuth();
  const [myStudents, setMyStudents] = useState<UserProfile[]>([]);
  const [allStudents, setAllStudents] = useState<UserProfile[]>([]);
  const [search, setSearch] = useState("");
  const [loading, setLoading] = useState(true);
  const [adding, setAdding] = useState<string | null>(null);

  async function fetchStudents() {
    if (!profile) return;
    const [mySnap, allSnap] = await Promise.all([
      getDocs(query(collection(db, "users"), where("teacherId", "==", profile.uid), where("role", "==", "student"))),
      getDocs(query(collection(db, "users"), where("role", "==", "student"))),
    ]);
    setMyStudents(mySnap.docs.map((d) => d.data() as UserProfile));
    setAllStudents(allSnap.docs.map((d) => d.data() as UserProfile));
    setLoading(false);
  }

  useEffect(() => {
    fetchStudents();
  }, [profile]);

  async function addStudent(student: UserProfile) {
    setAdding(student.uid);
    await updateDoc(doc(db, "users", student.uid), { teacherId: profile!.uid });
    await fetchStudents();
    setAdding(null);
  }

  async function removeStudent(student: UserProfile) {
    setAdding(student.uid);
    await updateDoc(doc(db, "users", student.uid), { teacherId: null });
    await fetchStudents();
    setAdding(null);
  }

  const myIds = new Set(myStudents.map((s) => s.uid));

  const unassigned = allStudents.filter(
    (s) => !myIds.has(s.uid) && s.name.toLowerCase().includes(search.toLowerCase())
  );

  return (
    <div>
      <h2 className="text-2xl font-bold text-gray-800 mb-1">Öğrenciler</h2>
      <p className="text-gray-500 text-sm mb-8">Sisteminize öğrenci ekleyin veya çıkarın.</p>

      <div className="grid md:grid-cols-2 gap-8">
        <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <h3 className="font-semibold text-gray-800 mb-4">Sisteminizdeki Öğrenciler ({myStudents.length})</h3>
          {loading ? (
            <p className="text-sm text-gray-400">Yükleniyor...</p>
          ) : myStudents.length === 0 ? (
            <p className="text-sm text-gray-400">Henüz öğrenci eklenmedi.</p>
          ) : (
            <ul className="space-y-2">
              {myStudents.map((s) => (
                <li key={s.uid} className="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
                  <div>
                    <p className="text-sm font-medium text-gray-800">{s.name}</p>
                    <p className="text-xs text-gray-400">{s.email}</p>
                  </div>
                  <button
                    onClick={() => removeStudent(s)}
                    disabled={adding === s.uid}
                    className="text-xs text-red-500 hover:text-red-700 transition disabled:opacity-50"
                  >
                    Çıkar
                  </button>
                </li>
              ))}
            </ul>
          )}
        </div>

        <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <h3 className="font-semibold text-gray-800 mb-4">Öğrenci Ara & Ekle</h3>
          <input
            type="text"
            placeholder="İsme göre ara..."
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            className="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-indigo-400"
          />
          {unassigned.length === 0 ? (
            <p className="text-sm text-gray-400">Eklenebilecek öğrenci bulunamadı.</p>
          ) : (
            <ul className="space-y-2 max-h-80 overflow-y-auto">
              {unassigned.map((s) => (
                <li key={s.uid} className="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
                  <div>
                    <p className="text-sm font-medium text-gray-800">{s.name}</p>
                    <p className="text-xs text-gray-400">{s.email}</p>
                  </div>
                  <button
                    onClick={() => addStudent(s)}
                    disabled={adding === s.uid}
                    className="text-xs bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5 rounded-lg transition disabled:opacity-50"
                  >
                    {adding === s.uid ? "..." : "Ekle"}
                  </button>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>
  );
}
